DB_NAME=tmdb
DB_USER=tm-user
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.terrameta.5ggeology.com
FRONTEND_URL=https://terrameta.5ggeology.com
# Icon URL for HTML emails (defaults to terrameta-logo-icon.png on the public frontend)
# EMAIL_LOGO_URL=https://terrameta.5ggeology.com/terrameta-logo-icon.png
CORS_ALLOWED_ORIGINS=http://localhost:3085,https://terrameta.5ggeology.com
CSRF_TRUSTED_ORIGINS=https://terrameta.5ggeology.com,https://api.terrameta.5ggeology.com

# ngrok (temporary public URL for local or demo access)
# NGROK_URL=https://4f38-197-250-140-161.ngrok-free.app
# NGROK_API_URL=https://your-api-subdomain.ngrok-free.app
# NGROK_ALLOW_WILDCARD=true

# Snippe payments (https://docs.snippe.sh/docs/)
SNIPPE_API_KEY=
SNIPPE_WEBHOOK_SECRET=
# SNIPPE_BASE_URL=https://api.snippe.sh
# Public API base used for webhook callbacks (e.g. https://api.terrameta.5ggeology.com)
# BACKEND_URL=https://api.terrameta.5ggeology.com

# Local dev only: auto-complete checkout without Snippe (never enable in production)
PAYMENTS_SIMULATE=true

# Max map layer upload size in bytes (default 50 MB)
# MAP_UPLOAD_MAX_BYTES=52428800
# BOUNDARY_UPLOAD_MAX_BYTES=52428800
# MAP_UPLOAD_MAX_FEATURES=50000
# BOUNDARY_UPLOAD_MAX_FEATURES=100000
# MAP_UPLOAD_MIN_FREE_BYTES=536870912
# MAP_ZIP_MAX_ENTRIES=200
# MAP_ZIP_MAX_UNCOMPRESSED_BYTES=104857600
# MAP_ZIP_MAX_COMPRESSION_RATIO=100

# Intelligence summaries - primary provider + fallbacks (ollama | groq | gemini)
AI_PROVIDER=groq
AI_PROVIDER_FALLBACK=gemini,ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Tavily web search (report writing assistant)
TAVILY_API_KEY=
TAVILY_MAX_RESULTS=5
TAVILY_SEARCH_ENABLED=true

REDIS_URL=redis://localhost:6379/0

EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=admin@5ggeology.com
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL="5G Geology Futures <admin@5ggeology.com>"

# Beem Africa SMS — phone OTP for sign-up / sign-in (https://beem.africa)
BEEM_SMS_API_KEY=
BEEM_SMS_SECRET_KEY=
BEEM_SMS_SOURCE_ADDR=NILEAGI
# BEEM_SMS_VERIFY_SSL=True

# Production overrides (used by deploy.sh)
# DEBUG=False
# GUNICORN_BIND=0.0.0.0:8085
# GUNICORN_WORKERS=3

AERIAL_INCLUDED_KM2=10
AERIAL_PRICE_PER_KM2=10000
AERIAL_MAX_ANALYSIS_KM2=300
AERIAL_MAX_BILLABLE_EXTRA_KM2=290

# Open-Elevation API for terrain context in Ask Terra insights (SRTM-based DEM)
# ELEVATION_API_URL=https://api.open-elevation.com/api/v1/lookup

# Ollama vision model for map snapshot analysis (LLaVA, moondream, etc.)
# OLLAMA_VISION_MODEL=llava